# PostgreSQL
POSTGRES_DB=ipng_db
POSTGRES_USER=ipng_user
POSTGRES_PASSWORD=ipng_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Derived — used by backend
DATABASE_URL=postgresql+asyncpg://ipng_user:ipng_pass@db:5432/ipng_db

# JWT
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
