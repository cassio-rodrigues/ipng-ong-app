# PostgreSQL
POSTGRES_DB=ipng_db
POSTGRES_USER=ipng_user
POSTGRES_PASSWORD=ipng_pass

# Derived — used by backend (troque 'db' pelo host se não usar Docker Compose)
DATABASE_URL=postgresql+asyncpg://ipng_user:ipng_pass@db:5432/ipng_db

# JWT — gere com: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
DEBUG=false

# CORS — origens permitidas (JSON array ou lista separada por vírgula)
# Desenvolvimento:
# CORS_ORIGINS=["http://localhost:3000"]
# Produção (substitua pelo seu domínio):
CORS_ORIGINS=["https://seudominio.com"]

# URL pública da API — usada no build do frontend
# Desenvolvimento: http://localhost:8000
# Produção (substitua pelo seu domínio):
NEXT_PUBLIC_API_URL=https://api.seudominio.com

# Domínio principal — usado pelo Nginx em produção
DOMAIN=seudominio.com
